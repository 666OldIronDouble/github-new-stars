# GitHub Token (可选，有 token 速率限制更高)
GITHUB_TOKEN=

# AI 后端选择: auto | ollama | gemini | siliconflow | deepseek | none
# auto: 自动检测可用后端，均不可用则降级为仅输出项目列表
AI_BACKEND=auto

# Ollama 配置 (本地服务，无需 API Key)
OLLAMA_MODEL=qwen3.5
OLLAMA_BASE_URL=http://localhost:11434

# Google Gemini 配置 (免费额度: 15 RPM)
# 获取 API Key: https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# 硅基流动配置 (OpenAI 兼容 API)
# 获取 API Key: https://cloud.siliconflow.cn/
SILICONFLOW_API_KEY=
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_MODEL=Qwen/Qwen3-8B

# DeepSeek 配置 (OpenAI 兼容 API)
# 获取 API Key: https://platform.deepseek.com/
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# 获取项目数量
TOP_N=10
